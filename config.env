# =============================================================================
#  MailBox — quraşdırma konfiqurasiyası
#  Bu faylı bir dəfə redaktə et, sonra install.sh onu istifadə edir.
#  DİQQƏT: burada gizli parol/açar SAXLAMA — bu fayl git-ə düşür.
# =============================================================================

# Mail serverin infrastruktur FQDN-i.
# Webmail + admin paneli bu ünvanda açılacaq: https://mail.example.com
# Bu ad SƏNİN idarə etdiyin bir domenin subdomeni olmalıdır (DNS-inə A qeydi yazacaqsan).
# Qeyd: bu "server adı"dır. Müştəri domenlərini (info@musteri.com və s.) sonra
#        panel üzərindən əlavə edəcəksən — burada yox.
MAIL_HOSTNAME=mailbox.tural.ai

# Serverin PUBLIC IPv4 ünvanı (DNS A qeydi və PTR üçün lazımdır).
SERVER_IP=168.231.108.200

# Saat qurşağı.
TIMEZONE=Asia/Baku

# Mailcow web UI-nin LOKAL portları — Caddy yalnız bunlara proxy edir.
# 127.0.0.1-ə bağlanır, xaricə açıq deyil. Başqa layihə ilə toqquşmasın deyə
# seçilib; dəyişməyə ehtiyac yoxdur.
MAILCOW_HTTP_PORT=8090
MAILCOW_HTTPS_PORT=8453

# Mailcow-un serverdə quraşdırılacağı qovluq (install.sh bunu yaradır/klonlayır).
MAILCOW_DIR=/opt/mailcow-dockerized

# --- Yeni domen üçün defolt kvotalar (MiB) -----------------------------------
# scripts/add-domain.sh və web panel bunlardan istifadə edir.
# DİQQƏT: burada sətir sonu şərhi yazma (# ...) — docker compose env_file
#         onu dəyərin bir hissəsi kimi oxuyur.
DOMAIN_MAX_ALIASES=400
DOMAIN_MAX_MAILBOXES=10
# yeni mailbox-un defolt kvotası
DOMAIN_DEFAULT_QUOTA=1024
DOMAIN_MAX_MAILBOX_QUOTA=5120
# domenin ümumi kvotası
DOMAIN_TOTAL_QUOTA=5120

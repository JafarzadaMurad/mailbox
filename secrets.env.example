# Mailcow API açarı.
# Paneldə yarat:  System → Configuration → Access → API
#   - "Activate API" işarələ
#   - "Read-Write access" seç
#   - "Allow API access from these IPs" sahəsinə serverin IP-sini yaz
#     (403 alsan, scripts/api-test.sh işlət — hansı IP-nin göründüyünü deyəcək)
MAILCOW_API_KEY=
